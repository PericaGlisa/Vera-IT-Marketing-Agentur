# Resend API Configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email Configuration
# The email address that will appear as the sender
FROM_EMAIL=noreply@verait.de

# The email address that will receive contact form submissions
CONTACT_EMAIL=info@verait.de

# Next.js Configuration
NEXT_PUBLIC_SITE_URL=https://verait.de

# Google Analytics Configuration
# Replace with your actual Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Facebook Pixel ID (uncomment when needed)
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789

# Optional: Google Ads ID (uncomment when needed)
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-123456789

# Optional: LinkedIn Insight Tag ID (uncomment when needed)
# NEXT_PUBLIC_LINKEDIN_INSIGHT_ID=123456

# Cookie Consent Configuration
# These are already set in the code but can be overridden if needed
# COOKIE_CONSENT_DURATION=31536000000
# COOKIE_CONSENT_VERSION=1.0